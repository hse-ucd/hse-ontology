@base <https://w3id.org/hse/ontology/> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix : <https://w3id.org/hse/ontology/> .
@prefix phi: <https://w3id.org/hse/ontology/phi#> .
@prefix phd: <https://w3id.org/hse/ontology/phd#> .
@prefix pht: <https://w3id.org/hse/terminology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix healthdcatap: <http://healthdataportal.eu/ns/health#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .

<#ClassesMapping>
  rml:logicalSource [
    rml:source "classes.csv" ;
    rml:referenceFormulation ql:CSV
  ] ;

  rr:subjectMap [
    rr:template "https://w3id.org/hse/ontology/phi#{URI}" ;
    rr:class rdfs:Class
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rml:reference "Label" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:comment ;
    rr:objectMap [ rml:reference "Comment" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:subClassOf ;
    rr:objectMap [ 
      rml:reference "SubClassOf" ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:source ;
    rr:objectMap [ rml:reference "Source" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:creator ;
    rr:objectMap [ rml:reference "Creator" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:contributor ;
    rr:objectMap [ rml:reference "Contributor" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:created ;
    rr:objectMap [ 
      rml:reference "Created" ;
      rr:datatype <http://www.w3.org/2001/XMLSchema#date>
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:modified ;
    rr:objectMap [ 
      rml:reference "Modified" ;
      rr:datatype <http://www.w3.org/2001/XMLSchema#date>
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:seeAlso ;
    rr:objectMap [ 
      rml:reference "SeeAlso" ;
      rr:termType rr:IRI
    ]
  ] .



# Static Ontology Metadata for phi: ontology
<#PhiOntologyMetadata>
  rml:logicalSource [
    rml:source "classes.csv" ;
    rml:referenceFormulation ql:CSV ;
    rml:iterator "$"
  ] ;

  rr:subjectMap [
    rr:constant <https://w3id.org/hse/ontology/phi#> ;
    rr:class owl:Ontology
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rr:constant "Population Health Indicator Ontology" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:comment ;
    rr:objectMap [ rr:constant "An ontology for describing population health indicators, created during the Older Adult Health and Wellbeing Profile project." ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:title ;
    rr:objectMap [ rr:constant "Population Health Indicator Ontology" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:description ;
    rr:objectMap [ rr:constant "Ontology for modeling population health indicators based on health DCAT-AP data catalogue" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate owl:versionInfo ;
    rr:objectMap [ rr:constant "1.0.4" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate owl:versionIRI ;
    rr:objectMap [ 
      rr:constant <https://w3id.org/hse/ontology/1.0.4/> ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate owl:priorVersion ;
    rr:objectMap [ 
      rr:constant <https://w3id.org/hse/ontology/1.0.3/> ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:issued ;
    rr:objectMap [ 
      rr:constant "2025-08-20" ;
      rr:datatype xsd:date
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:modified ;
    rr:objectMap [ 
      rr:constant "2026-04-14" ;
      rr:datatype xsd:date
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:creator ;
    rr:objectMap [ rr:constant "Rob Brennan, ADAPT UCD" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:contributor ;
    rr:objectMap [ rr:constant "Junli Liang, ADAPT UCD" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:contributor ;
    rr:objectMap [ rr:constant "Huan Chen, UCD" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:contributor ;
    rr:objectMap [ rr:constant "Haula Galadima, ADAPT UCD" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:source ;
    rr:objectMap [ 
      rr:constant "The OAHP project" ;
      rr:termType rr:Literal
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:seeAlso ;
    rr:objectMap [ 
      rr:constant <https://openreview.net/pdf?id=JMWarUh56o> ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:license ;
    rr:objectMap [ 
      rr:constant <https://creativecommons.org/licenses/by/4.0/> ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:rights ;
    rr:objectMap [ rr:constant "Copyright © 2025 Health Service Executive (HSE) and University College Dublin (UCD). This work is licensed under a Creative Commons Attribution 4.0 International License." ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:abstract ;
    rr:objectMap [ rr:constant """The Population Health Indicator Ontology (phi) provides a formal vocabulary for describing population health indicators, indicator groups and the data sources that are used for the indicator numerators and denominators. It is based on HealthDCAT-AP Release 5, the Data Privacy Vocabulary (DPV) and a review of international digital population health indicator metadata. Specific influences were NHS Fingertips,THL Sotkanet Indicator Bank and HSE population health indicator metadata. It is designed to enable the cataloguing and feasibility assessment of indicators and supporting datasets for a population health profile process.

This ontology was developed by the Research Ireland ADAPT Centre at UCD as part of the Ageing Well in Later Life Profile project under Health Service Executive National Clinical Programme for Older People Research Award 2024 (NCPOP RA3/2024). This research was conducted with the financial support of Research Ireland under the ADAPT Centre for AI-driven Digital Content Technology which is funded under the Research Ireland Research Centres Programme (Grant 13/RC/2106_P2) and EMPOWER Data Governance under the Research Ireland Spokes Programme (Grant 20/SP/8955).""" ] ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:publisher ;
    rr:objectMap [ rr:constant "ADAPT Centre, University College Dublin" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate vann:preferredNamespacePrefix ;
    rr:objectMap [ rr:constant "phi" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate vann:preferredNamespaceUri ;
    rr:objectMap [ rr:constant "https://w3id.org/hse/ontology/" ]
  ] ;


  rr:predicateObjectMap [
    rr:predicate bibo:status ;
    rr:objectMap [ rr:constant "Draft" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate foaf:homepage ;
    rr:objectMap [ 
      rr:constant <https://w3id.org/hse/ontology/> ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:bibliographicCitation ;
    rr:objectMap [ 
      rr:constant """Rob Brennan, Junli Liang and Akila Wickramasekara, Prototyping a Health DCAT-AP data catalogue to support population health indicator identification and quality assessment, NeXt-generation Data Governance workshop 2025 (NXDG 2025), https://ceur-ws.org/Vol-4064/NXDG25-paper3.pdf """ ;]
  ]
  .

# DatatypeProperty Mapping
<#DatatypePropertiesMapping>
  rml:logicalSource [
    rml:source "datatype_properties.csv" ;
    rml:referenceFormulation ql:CSV
  ] ;

  rr:subjectMap [
    rml:reference "URI" ;
    rr:termType rr:IRI ;
    rr:class owl:DatatypeProperty
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rml:reference "Label" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:comment ;
    rr:objectMap [ rml:reference "Comment" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:subPropertyOf ;
    rr:objectMap [ 
      rml:reference "SubPropertyOf" ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:domain ;
    rr:objectMap [ 
      rml:reference "Domain" ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:range ;
    rr:objectMap [ 
      rml:reference "Range" ;
      rr:termType rr:IRI
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:source ;
    rr:objectMap [ rml:reference "Source" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:creator ;
    rr:objectMap [ rml:reference "Creator" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:contributor ;
    rr:objectMap [ rml:reference "Contributor" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:created ;
    rr:objectMap [ 
      rml:reference "Created" ;
      rr:datatype xsd:date
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate dcterms:modified ;
    rr:objectMap [ 
      rml:reference "Modified" ;
      rr:datatype xsd:date
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:seeAlso ;
    rr:objectMap [ 
      rml:reference "SeeAlso" ;
      rr:termType rr:IRI
    ]
  ] .

