    <!-- https://w3id.org/hse/ontology/phd#hasCodingScheme -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phd#hasCodingScheme">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
