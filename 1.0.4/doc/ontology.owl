        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Reasons for Inclusion or Exclusion</rdfs:comment>
        <rdfs:label>Reasons for Inclusion/Exclusion</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#identifier -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#identifier">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>The main identifier for the Indicator, e.g. the URI [URL, web link] or other unique identifier in the context of the Catalogue.</rdfs:comment>
        <rdfs:label>Indicator ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#measurementLimitations -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#measurementLimitations">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Notes on limitations or uncertainty introduced by how the data are collected or calculated.</rdfs:comment>
        <rdfs:label>Measurement Limitations</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#methodology -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#methodology">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Summary of methods used to calculate the indicator (e.,g statistical technique, smoothing, standardisation, modelling).</rdfs:comment>
        <rdfs:label>Methodology</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#note -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#note">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Any additional informal information about the dataset or indicator</rdfs:comment>
        <rdfs:label>Notes</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#numeratorDataElement -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#numeratorDataElement">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>The description of one variable or value that is used in the numerator e.g. number of deaths. Multiple data elements may be present as a list.</rdfs:comment>
        <rdfs:label>Numerator Data Element</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#provenance -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#provenance">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/provenance"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Provenance is information about entities, activities, and people involved in producing an indicator, which can be used to form assessments about its quality, reliability or trustworthiness. For example a description of the source of this indicator, e.g. academic papers or standards, any calculations or adjustments performed on the raw data and any organisations involved in producing or transforming the data.</rdfs:comment>
        <rdfs:label>Provenance</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#rationale -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#rationale">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>A summary explaining why this indicator matters—its relevance to population health, what it helps to understand, and how it complements other indicators.</rdfs:comment>
        <rdfs:label>Rationale</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#title -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#title">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/title"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Full name of the indicator as used in reports or dashboards.</rdfs:comment>
        <rdfs:label>Indicator Title</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#validityGuidance -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#validityGuidance">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Description of how the indicator might be influenced by other variables or biases, affecting validity.</rdfs:comment>
        <rdfs:label>Validity Guidance</rdfs:label>
    </owl:DatatypeProperty>
    


