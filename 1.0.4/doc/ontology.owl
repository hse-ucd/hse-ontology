    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#definition -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#definition">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Technical description of the indicator—what it measures, how it&apos;s defined, and any assumptions or limitations in interpretation.</rdfs:comment>
        <rdfs:label>Definition</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#denominatorDataElement -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#denominatorDataElement">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>The description of one variable or value that is used in the denominator (if this indicator has one) e.g. population size. Multiple data elements may be present as a list.</rdfs:comment>
        <rdfs:label>Denominator Data Element</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#disaggregation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#disaggregation">
