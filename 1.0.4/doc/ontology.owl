<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/hse/ontology/phi#"
     xml:base="https://w3id.org/hse/ontology/phi"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/hse/ontology/phi#">
        <owl:versionIRI rdf:resource="https://w3id.org/hse/ontology/1.0.4/"/>
        <terms:abstract>The Population Health Indicator Ontology (phi) provides a formal vocabulary for describing population health indicators, indicator groups and the data sources that are used for the indicator numerators and denominators. It is based on HealthDCAT-AP Release 5, the Data Privacy Vocabulary (DPV) and a review of international digital population health indicator metadata. Specific influences were NHS Fingertips,THL Sotkanet Indicator Bank and HSE population health indicator metadata. It is designed to enable the cataloguing and feasibility assessment of indicators and supporting datasets for a population health profile process.

This ontology was developed by the Research Ireland ADAPT Centre at UCD as part of the Ageing Well in Later Life Profile project under Health Service Executive National Clinical Programme for Older People Research Award 2024 (NCPOP RA3/2024). This research was conducted with the financial support of Research Ireland under the ADAPT Centre for AI-driven Digital Content Technology which is funded under the Research Ireland Research Centres Programme (Grant 13/RC/2106_P2) and EMPOWER Data Governance under the Research Ireland Spokes Programme (Grant 20/SP/8955).</terms:abstract>
        <terms:bibliographicCitation>Rob Brennan, Junli Liang and Akila Wickramasekara, Prototyping a Health DCAT-AP data catalogue to support population health indicator identification and quality assessment, NeXt-generation Data Governance workshop 2025 (NXDG 2025), https://ceur-ws.org/Vol-4064/NXDG25-paper3.pdf </terms:bibliographicCitation>
        <terms:contributor>Haula Galadima, ADAPT UCD</terms:contributor>
        <terms:contributor>Huan Chen, UCD</terms:contributor>
        <terms:contributor>Junli Liang, ADAPT UCD</terms:contributor>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:description>Ontology for modeling population health indicators based on health DCAT-AP data catalogue</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-20</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-14</terms:modified>
        <terms:publisher>ADAPT Centre, University College Dublin</terms:publisher>
        <terms:rights>Copyright © 2025 Health Service Executive (HSE) and University College Dublin (UCD). This work is licensed under a Creative Commons Attribution 4.0 International License.</terms:rights>
        <terms:source>The OAHP project</terms:source>
        <bibo:status>Draft</bibo:status>
        <vann:preferredNamespacePrefix>phi</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/hse/ontology/</vann:preferredNamespaceUri>
        <rdfs:comment>An ontology for describing population health indicators, created during the Older Adult Health and Wellbeing Profile project.</rdfs:comment>
        <rdfs:label>Population Health Indicator Ontology</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://openreview.net/pdf?id=JMWarUh56o"/>
        <owl:priorVersion rdf:resource="https://w3id.org/hse/ontology/1.0.3/"/>
        <owl:versionInfo>1.0.4</owl:versionInfo>
        <foaf:homepage rdf:resource="https://w3id.org/hse/ontology/"/>
    </owl:Ontology>
    


