    <!-- http://www.w3.org/ns/dcat#Dataset -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Dataset"/>
    


    <!-- https://w3id.org/hse/ontology/phi#Dataset -->


    <owl:Class rdf:about="https://w3id.org/hse/ontology/phi#Dataset">
        <rdfs:subClassOf rdf:resource="https://www.w3.org/TR/vocab-dcat-3/#Class:Dataset"/>
        <terms:contributor>Huan Chen, ADAPT UCD</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-04-25</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-11</terms:modified>
