             <http://purl.org/dc/terms/source> "OAHP Data Catalogue Schema Proposal v05.13" ;
             rdfs:comment "Reasons for Inclusion or Exclusion" ;
             rdfs:label "Reasons for Inclusion/Exclusion" .


###  https://w3id.org/hse/ontology/phi#identifier
:identifier rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
            rdfs:domain :Indicator ;
            rdfs:range xsd:anyURI ;
