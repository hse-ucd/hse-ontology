            <http://purl.org/dc/terms/creator> "Rob Brennan, ADAPT UCD" ;
            <http://purl.org/dc/terms/modified> "2025-08-29"^^xsd:date ;
            <http://purl.org/dc/terms/source> "OAHP Data Catalogue Schema Proposal v05.13" ;
            rdfs:comment "The main identifier for the Indicator, e.g. the URI [URL, web link] or other unique identifier in the context of the Catalogue." ;
            rdfs:label "Indicator ID" .


###  https://w3id.org/hse/ontology/phi#measurementLimitations
:measurementLimitations rdf:type owl:DatatypeProperty ;
