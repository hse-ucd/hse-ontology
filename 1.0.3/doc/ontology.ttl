###  https://w3id.org/hse/ontology/phi#definition
:definition rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#definition> ;
            rdfs:domain :Indicator ;
            rdfs:range xsd:string ;
            <http://purl.org/dc/terms/created> "2025-08-18"^^xsd:date ;
            <http://purl.org/dc/terms/creator> "Rob Brennan, ADAPT UCD" ;
            <http://purl.org/dc/terms/modified> "2025-08-29"^^xsd:date ;
            <http://purl.org/dc/terms/source> "OAHP Data Catalogue Schema Proposal v05.13" ;
            rdfs:comment "Technical description of the indicator—what it measures, how it's defined, and any assumptions or limitations in interpretation." ;
            rdfs:label "Definition" .


###  https://w3id.org/hse/ontology/phi#denominatorDataElement
:denominatorDataElement rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Indicator ;
                        rdfs:range xsd:string ;
                        <http://purl.org/dc/terms/created> "2025-08-18"^^xsd:date ;
                        <http://purl.org/dc/terms/creator> "Rob Brennan, ADAPT UCD" ;
                        <http://purl.org/dc/terms/modified> "2025-08-29"^^xsd:date ;
                        <http://purl.org/dc/terms/source> "OAHP Data Catalogue Schema Proposal v05.13" ;
                        rdfs:comment "The description of one variable or value that is used in the denominator (if this indicator has one) e.g. population size. Multiple data elements may be present as a list." ;
                        rdfs:label "Denominator Data Element" .


###  https://w3id.org/hse/ontology/phi#disaggregation
:disaggregation rdf:type owl:DatatypeProperty ;
                rdfs:domain :Indicator ;
                rdfs:range xsd:string ;
