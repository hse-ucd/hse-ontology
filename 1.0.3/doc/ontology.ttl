                <http://purl.org/dc/terms/creator> "Rob Brennan, ADAPT UCD" ;
                <http://purl.org/dc/terms/modified> "2025-08-29"^^xsd:date ;
                <http://purl.org/dc/terms/source> "OAHP Data Catalogue Schema Proposal v05.13" ;
                rdfs:comment "A list of disaggregation conditions that should be available e.g. male and female" ;
                rdfs:label "Disaggregations" .


###  https://w3id.org/hse/ontology/phi#highLowGuidance
:highLowGuidance rdf:type owl:DatatypeProperty ;
