     -->


    


    <!-- https://w3id.org/hse/ontology/phd#hasCodingScheme -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phd#hasCodingScheme">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:contributor>Huan Chen, UCD</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-04-25</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-11</terms:modified>
        <terms:source>DCAT3</terms:source>
        <rdfs:comment>Coding systems in use (ex: ICD-10-CM, DGRs, SNOMED=CT, ...)</rdfs:comment>
        <rdfs:label>Has Coding Scheme</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phd#spatialAggregation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phd#spatialAggregation">
        <terms:contributor>PHD</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">Rob Brennan, ADAPT UCD</terms:created>
        <terms:creator>https://w3id.org/hse/terminology#SpatialGranularityCode</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">Junli Liang, UCD</terms:modified>
        <terms:source>http://www.w3.org/ns/dcat#Dataset</terms:source>
        <rdfs:comment> &quot;List the smallest spatial aggregatation size available in the dataset</rdfs:comment>
        <rdfs:label> Spatial Aggregation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://w3id.org/hse/2025-04-25"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phd#status -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phd#status">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:contributor>Huan Chen, UCD</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-04-25</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-11</terms:modified>
        <terms:source>PHD</terms:source>
        <rdfs:comment>An internal prioritisation process status for the dataset or indicator</rdfs:comment>
        <rdfs:label>Status</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.w3.org/TR/vocab-dcat-3/#Property:resource_status"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#denominatorDataElement -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#denominatorDataElement">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>The description of one variable or value that is used in the denominator (if this indicator has one) e.g. population size. Multiple data elements may be present as a list.</rdfs:comment>
        <rdfs:label>Denominator Data Element</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#disaggregation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#disaggregation">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>A list of disaggregation conditions that should be available e.g. male and female</rdfs:comment>
        <rdfs:label>Disaggregations</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#highLowGuidance -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#highLowGuidance">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Guidance on how to understand high or low values—whether they suggest good or poor outcomes.</rdfs:comment>
        <rdfs:label>High-Low Guidance</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#measurementLimitations -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#measurementLimitations">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Notes on limitations or uncertainty introduced by how the data are collected or calculated.</rdfs:comment>
        <rdfs:label>Measurement Limitations</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#methodology -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#methodology">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Summary of methods used to calculate the indicator (e.,g statistical technique, smoothing, standardisation, modelling).</rdfs:comment>
        <rdfs:label>Methodology</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#numeratorDataElement -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/hse/ontology/phi#numeratorDataElement">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
