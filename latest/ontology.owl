    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/accrualPeriodicity -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/accrualPeriodicity"/>
    


    <!-- http://www.w3.org/2002/07/owl#sameAs -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#sameAs"/>
    


    <!-- https://w3id.org/hse/ontology/phd#applicableLegislation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phd#applicableLegislation">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Resource"/>
        <terms:contributor>Huan Chen, UCD</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-04-25</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-11</terms:modified>
        <terms:source>DCAT3</terms:source>
        <rdfs:comment>The legislation that mandates the creation or management of the Dataset.</rdfs:comment>
        <rdfs:label>Applicable Legislation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#accrualPeriodicity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#accrualPeriodicity">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/accrualPeriodicity"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Frequency of indicator update in report, e.g. daily or monthly. This is used with the reporting style to determine the exact frequency and lag of indicator reports.Note that datasets have their own -Frequency of data updates- field to state how often they are updated.</rdfs:comment>
        <rdfs:label>Report Frequency</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#denominatorSource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#denominatorSource">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Identifier, e.g. URL, for the dataset providing a denominator data element. If there are multiple denominator data elements then multiple datasets must be provided as a list.</rdfs:comment>
        <rdfs:label>Denominator Source Dataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#domain -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#domain">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>The high-level category the indicator falls under (e.g. Demography).</rdfs:comment>
        <rdfs:label>Domain</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://healthdataportal.eu/ns/health#healthTheme"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#indicatorType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#indicatorType">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Specifies if the indicator has both a numerator and a denominator, is coverage, accumulated or qualitative type</rdfs:comment>
        <rdfs:label>Indicator Type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#memberOfGroup -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#memberOfGroup">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="https://w3id.org/hse/ontology/phi#IndicatorGroup"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-01</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-01</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Indicates that this indicator is a member of an indicator group.</rdfs:comment>
        <rdfs:label>Member of Indicator Group</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#numeratorSource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#numeratorSource">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Identifier, e.g. URL, for the dataset providing a numerator data element. If there are multiple numerator data elements then multiple datasets must be provided as a list.</rdfs:comment>
        <rdfs:label>Numerator Source Dataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#otherIdentifier -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#otherIdentifier">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#sameAs"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>Alternative identifiers for this indicator from other data publishers or coding schemes (as URIs)</rdfs:comment>
        <rdfs:label>Other Identifiers</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#status -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#status">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="https://w3id.org/hse/terminology#StatusCode"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hse/ontology/phi#subdomain -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hse/ontology/phi#subdomain">
        <rdfs:domain rdf:resource="https://w3id.org/hse/ontology/phi#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-18</terms:created>
        <terms:creator>Rob Brennan, ADAPT UCD</terms:creator>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-08-29</terms:modified>
        <terms:source>OAHP Data Catalogue Schema Proposal v05.13</terms:source>
        <rdfs:comment>A more specific category under the domain (e.g. Population numbers).</rdfs:comment>
        <rdfs:label>Subdomain</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://healthdataportal.eu/ns/health#healthTheme"/>
    </owl:ObjectProperty>
    


